# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/postify"

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET="your-very-long-random-jwt-secret-at-least-32-chars"

# ─── Encryption (AES-256) ────────────────────────────────────────────────────
ENCRYPTION_KEY="your-very-long-random-encryption-key-at-least-32-chars"

# ─── AI APIs ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."     # App-level fallback key (optional if users bring their own)

# ─── Google / YouTube ────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Meta / Instagram ────────────────────────────────────────────────────────
META_CLIENT_ID="your-meta-app-id"
META_CLIENT_SECRET="your-meta-app-secret"

# ─── TikTok ──────────────────────────────────────────────────────────────────
TIKTOK_CLIENT_ID="your-tiktok-client-key"
TIKTOK_CLIENT_SECRET="your-tiktok-client-secret"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV="development"
SERVER_URL="http://localhost:5000"       # Public-facing server URL (used for OAuth callbacks)
CLIENT_URL="http://localhost:5173"       # Frontend URL (used for CORS and OAuth redirects)
